case $- in
  *i*) ;;
  *) return ;;
esac

if [ -f "$HOME/.config/sh/shared.sh" ]; then
  . "$HOME/.config/sh/shared.sh"
fi

if [ -f "$HOME/.config/sh/local.sh" ]; then
  . "$HOME/.config/sh/local.sh"
fi

dotfiles_source_bash_completion_file() {
  dotfiles_source_first "$@"
}

dotfiles_init_bash_completion() {
  local dotfiles_brew_root dotfiles_bash_completion_dir dotfiles_share_completion_dir
  local dotfiles_cargo_completion

  dotfiles_source_first \
    "$HOME/.local/share/bash-completion/bash_completion" \
    "${HOMEBREW_PREFIX:-}/etc/profile.d/bash_completion.sh" \
    /opt/homebrew/etc/profile.d/bash_completion.sh \
    /usr/local/etc/profile.d/bash_completion.sh \
    /usr/share/bash-completion/bash_completion \
    /etc/bash_completion

  dotfiles_brew_root="$(dotfiles_brew_prefix 2>/dev/null || true)"
  dotfiles_bash_completion_dir=""
  dotfiles_share_completion_dir=""

  if [ -n "$dotfiles_brew_root" ]; then
    dotfiles_bash_completion_dir="$dotfiles_brew_root/etc/bash_completion.d"
    dotfiles_share_completion_dir="$dotfiles_brew_root/share/bash-completion/completions"
  fi

  if command -v git >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/git-completion.bash" \
      "$dotfiles_share_completion_dir/git" \
      /usr/share/bash-completion/completions/git
  fi

  if command -v brew >/dev/null 2>&1 && [ -n "$dotfiles_bash_completion_dir" ]; then
    dotfiles_source_bash_completion_file "$dotfiles_bash_completion_dir/brew"
  fi

  if command -v eza >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/eza" \
      /usr/share/bash-completion/completions/eza
  fi

  if command -v fd >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/fd" \
      /usr/share/bash-completion/completions/fd
  fi

  if command -v rg >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/rg" \
      /usr/share/bash-completion/completions/rg
  fi

  if command -v uv >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/uv" \
      /usr/share/bash-completion/completions/uv
  fi

  if command -v zoxide >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/zoxide" \
      /usr/share/bash-completion/completions/zoxide
  fi

  if command -v gh >/dev/null 2>&1 && declare -F _get_comp_words_by_ref >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/gh" \
      /usr/share/bash-completion/completions/gh
  fi

  if command -v bat >/dev/null 2>&1 && declare -F _get_comp_words_by_ref >/dev/null 2>&1 && declare -F _split_longopt >/dev/null 2>&1; then
    dotfiles_source_bash_completion_file \
      "$dotfiles_bash_completion_dir/bat" \
      /usr/share/bash-completion/completions/bat
  fi

  if command -v pnpm >/dev/null 2>&1; then
    eval "$(SHELL=bash pnpm completion bash 2>/dev/null)"
  fi

  if command -v node >/dev/null 2>&1; then
    eval "$(node --completion-bash 2>/dev/null)"
  fi

  if command -v cargo >/dev/null 2>&1 && command -v rustc >/dev/null 2>&1; then
    dotfiles_cargo_completion="$(dotfiles_rustup_sysroot 2>/dev/null || true)/etc/bash_completion.d/cargo"
    if [ -r "$dotfiles_cargo_completion" ]; then
      . "$dotfiles_cargo_completion"
    fi
  fi

  unset dotfiles_brew_root dotfiles_bash_completion_dir dotfiles_share_completion_dir dotfiles_cargo_completion
}

if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell bash)"
fi

dotfiles_init_bash_completion
unset -f dotfiles_source_bash_completion_file dotfiles_init_bash_completion

if [ -f "$HOME/.config/sh/fzf.sh" ]; then
  . "$HOME/.config/sh/fzf.sh"
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init bash)"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
fi
