if [ -f "$HOME/.config/sh/shared.sh" ]; then
  . "$HOME/.config/sh/shared.sh"
fi

if [ -f "$HOME/.config/sh/local.sh" ]; then
  . "$HOME/.config/sh/local.sh"
fi

typeset -U fpath

if [ -d "$HOME/.local/share/zsh/site-functions" ]; then
  fpath=("$HOME/.local/share/zsh/site-functions" $fpath)
fi

dotfiles_brew_root="$(dotfiles_brew_prefix 2>/dev/null || true)"
if [ -n "$dotfiles_brew_root" ] && [ -d "$dotfiles_brew_root/share/zsh/site-functions" ]; then
  fpath=("$dotfiles_brew_root/share/zsh/site-functions" $fpath)
fi

dotfiles_bun_completion_root="$(dotfiles_bun_root 2>/dev/null || true)"
if [ -n "$dotfiles_bun_completion_root" ] && [ -r "$dotfiles_bun_completion_root/_bun" ]; then
  fpath=("$dotfiles_bun_completion_root" $fpath)
fi

if command -v cargo >/dev/null 2>&1 && command -v rustc >/dev/null 2>&1; then
  dotfiles_cargo_completion_dir="$(dotfiles_rustup_sysroot 2>/dev/null || true)/share/zsh/site-functions"
  if [ -d "$dotfiles_cargo_completion_dir" ]; then
    fpath=("$dotfiles_cargo_completion_dir" $fpath)
  fi
  unset dotfiles_cargo_completion_dir
fi

autoload -Uz compinit
compinit -u

if [ -f "$HOME/.config/sh/fzf.sh" ]; then
  . "$HOME/.config/sh/fzf.sh"
fi

if command -v pnpm >/dev/null 2>&1; then
  eval "$(SHELL=zsh pnpm completion zsh 2>/dev/null)"
fi

if [ -n "$dotfiles_bun_completion_root" ] && [ -r "$dotfiles_bun_completion_root/_bun" ]; then
  autoload -Uz _bun
  compdef _bun bun
fi

if command -v cargo >/dev/null 2>&1; then
  autoload -Uz _cargo
  if whence -w _cargo >/dev/null 2>&1; then
    compdef _cargo cargo
  fi
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

if [ -f "$HOME/.config/sh/ssh-tmux.sh" ]; then
  . "$HOME/.config/sh/ssh-tmux.sh"
fi

unset dotfiles_brew_root dotfiles_bun_completion_root
