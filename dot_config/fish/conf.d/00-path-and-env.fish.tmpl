{{ $bootstrap := get . "bootstrap" | default dict }}

{{- range .shell.path_entries }}
fish_add_path -p "$HOME/{{ . }}"
{{- end }}

{{- if get $bootstrap "install_desktop_vnc" | default false }}
set -gx DISPLAY :99
{{- end }}

{{- if get $bootstrap "install_openclaw" | default false }}
set -gx NODE_COMPILE_CACHE /var/tmp/openclaw-compile-cache
set -gx OPENCLAW_NO_RESPAWN 1
{{- end }}

if test "$TERM" = "xterm-ghostty"
    if set -q SSH_CONNECTION; or set -q SSH_CLIENT; or set -q SSH_TTY
        set -gx TERM xterm-256color
        set -e TERMINFO
    else if not command -q infocmp; or not infocmp xterm-ghostty >/dev/null 2>&1
        set -gx TERM xterm-256color
        set -e TERMINFO
    end
end
