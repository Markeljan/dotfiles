#!/usr/bin/env bash
set -euo pipefail

target="${1:-}"

have() {
  command -v "$1" >/dev/null 2>&1
}

preview_with_bat() {
  if have bat; then
    bat --color=always --style=header,grid --line-range=:500 "$1"
  elif have batcat; then
    batcat --color=always --style=header,grid --line-range=:500 "$1"
  else
    sed -n '1,500p' "$1"
  fi
}

if [ -z "$target" ]; then
  exit 0
fi

if [ -f "$target" ]; then
  if file --mime "$target" 2>/dev/null | grep -q 'image/'; then
    if have chafa; then
      chafa "$target"
    else
      printf '%s\n' "$target"
    fi
  else
    preview_with_bat "$target"
  fi
  exit 0
fi

if [ -d "$target" ]; then
  if have eza; then
    eza --tree --level=4 --color=always "$target"
  elif have exa; then
    exa --tree --level=4 --color=always "$target"
  else
    ls -la "$target"
  fi
  exit 0
fi

if printenv "$target" >/dev/null 2>&1; then
  printenv "$target"
  exit 0
fi

if have "$target"; then
  "$target" --help 2>/dev/null || man "$target" 2>/dev/null || printf '%s\n' "$target"
  exit 0
fi

printf '%s\n' "$target"

