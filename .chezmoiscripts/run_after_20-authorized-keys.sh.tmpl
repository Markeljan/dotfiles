#!/usr/bin/env bash
set -euo pipefail

local_file="$HOME/.ssh/authorized_keys.local"
legacy_shared_file="$HOME/.ssh/authorized_keys.shared"
target_file="$HOME/.ssh/authorized_keys"
temp_file="$(mktemp)"

append_repo_authorized_keys() {
  cat <<'EOF'
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILwXOaRFvzRwWE6lRt4DMK26VSR4e2b2hWQ7IEfi09Xa
EOF
}

cleanup() {
  rm -f "$temp_file"
}

trap cleanup EXIT

mkdir -p "$HOME/.ssh"

if [ -f "$target_file" ]; then
  cat "$target_file" >> "$temp_file"
fi

if [ -f "$legacy_shared_file" ]; then
  cat "$legacy_shared_file" >> "$temp_file"
fi

append_repo_authorized_keys >> "$temp_file"

if [ -f "$local_file" ]; then
  cat "$local_file" >> "$temp_file"
fi

awk 'NF && !seen[$0]++ { print }' "$temp_file" > "${temp_file}.filtered" || true
mv "${temp_file}.filtered" "$temp_file"

if [ -s "$temp_file" ]; then
  printf '\n' >> "$temp_file"
else
  : > "$temp_file"
fi

mv "$temp_file" "$target_file"
chmod 600 "$target_file"
