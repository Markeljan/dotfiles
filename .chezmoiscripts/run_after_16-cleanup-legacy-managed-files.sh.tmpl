#!/usr/bin/env bash
set -euo pipefail

remove_if_template_matches() {
  local path="$1"
  local tmp_file

  if [ ! -f "$path" ]; then
    cat >/dev/null
    return
  fi

  tmp_file="$(mktemp)"
  cat >"$tmp_file"

  if cmp -s "$path" "$tmp_file"; then
    rm -f "$path"
  fi

  rm -f "$tmp_file"
}

remove_if_template_matches "$HOME/CLAUDE.md" <<'EOF'
@AGENTS.md
EOF

remove_if_template_matches "$HOME/.config/sh/ssh-tmux.sh" <<'EOF'
dotfiles_auto_tmux_attach() {
  if [ -n "${TMUX:-}" ]; then
    return
  fi

  if [ -z "${SSH_CONNECTION:-}" ]; then
    return
  fi

  if [ -n "${SSH_ORIGINAL_COMMAND:-}" ]; then
    return
  fi

  if ! command -v tmux >/dev/null 2>&1; then
    return
  fi

  exec tmux new-session -A -s "main"
}

dotfiles_auto_tmux_attach
EOF

remove_if_template_matches "$HOME/.config/fish/conf.d/30-ssh-tmux.fish" <<'EOF'
if status is-interactive
    if set -q SSH_CONNECTION
        if not set -q TMUX
            if not set -q SSH_ORIGINAL_COMMAND
                if command -q tmux
                    exec tmux new-session -A -s "main"
                end
            end
        end
    end
end
EOF

remove_if_template_matches "$HOME/.tmux.conf" <<'EOF'
set -g status off
set -g mouse on
set -g history-limit 100000
setw -g mode-keys vi

bind r source-file ~/.tmux.conf \; display-message "tmux config reloaded"

if-shell 'test -f ~/.tmux.local.conf' 'source-file ~/.tmux.local.conf'
EOF

if [ -f "$HOME/.config/nvim/init.lua" ] && [ -e "$HOME/.config/nvim/init.vim" ]; then
  rm -f "$HOME/.config/nvim/init.vim"
fi

# Older revisions created ~/bin even though the repo now standardizes on ~/.local/bin.
rmdir "$HOME/bin" 2>/dev/null || true
remove_if_template_matches "$HOME/.ssh/authorized_keys.shared" <<'EOF'
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILwXOaRFvzRwWE6lRt4DMK26VSR4e2b2hWQ7IEfi09Xa
EOF
rm -f "$HOME/.ssh/config.shared"
