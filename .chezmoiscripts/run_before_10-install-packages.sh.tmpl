#!/usr/bin/env bash
set -euo pipefail

{{ $bootstrap := get . "bootstrap" | default dict }}
{{ $linuxSshBootstrapExtras := get $bootstrap "linux_ssh_extras" | default list }}
{{ $installLegacyXfceDesktop := or (get $bootstrap "install_xfce_desktop" | default false) (has "xfce-desktop" $linuxSshBootstrapExtras) }}
{{ $installDesktopVnc := or (get $bootstrap "install_desktop_vnc" | default false) (has "desktop-vnc" $linuxSshBootstrapExtras) }}
{{ $installDesktopRdp := or (get $bootstrap "install_desktop_rdp" | default false) (has "desktop-rdp" $linuxSshBootstrapExtras) $installLegacyXfceDesktop }}
{{ $installChrome := or (get $bootstrap "install_chrome" | default false) $installDesktopVnc $installDesktopRdp }}
{{ $installOpenClaw := get $bootstrap "install_openclaw" | default false }}
{{ $vncServiceName := "dotfiles-vnc-display.service" }}
{{ $vncServicePath := printf "/etc/systemd/system/%s" $vncServiceName }}
{{ $vncStartScript := printf "%s/.local/bin/dotfiles-start-vnc-display" .chezmoi.homeDir }}
{{ $openClawCompileCache := "/var/tmp/openclaw-compile-cache" }}

log() {
  printf '[dotfiles packages] %s\n' "$*"
}

warn() {
  printf '[dotfiles packages] warning: %s\n' "$*" >&2
}

have() {
  command -v "$1" >/dev/null 2>&1
}

run_sudo() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif have sudo; then
    sudo "$@"
  else
    warn "sudo is required to install system packages"
    return 1
  fi
}

download() {
  if have curl; then
    curl -fsSL "$1"
  elif have wget; then
    wget -qO- "$1"
  else
    warn "curl or wget is required"
    return 1
  fi
}

download_to() {
  if have curl; then
    curl --fail --silent --show-error --location --output "$2" "$1"
  elif have wget; then
    wget -qO "$2" "$1"
  else
    warn "curl or wget is required"
    return 1
  fi
}

ensure_local_bin() {
  mkdir -p "$HOME/.local/bin"

  case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
  esac

  case ":$PATH:" in
    *":$HOME/.bun/bin:"*) ;;
    *) export PATH="$HOME/.bun/bin:$PATH" ;;
  esac
}

brew_path() {
  if have brew; then
    command -v brew
    return
  fi

  {{- range .shell.brew_candidates }}
  if [ -x "{{ . }}" ]; then
    printf '%s\n' "{{ . }}"
    return
  fi
  {{- end }}

  return 1
}

install_homebrew() {
  if brew_path >/dev/null 2>&1; then
    return
  fi

  if [ "$(uname -s)" = "Linux" ] && [ "$(id -u)" -eq 0 ]; then
    warn "Homebrew on Linux requires a non-root user"
    return 1
  fi

  log "installing Homebrew"
  NONINTERACTIVE=1 CI=1 /bin/bash -c "$(download "https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh")"
}

eval_brew_shellenv() {
  local brew_bin

  brew_bin="$(brew_path 2>/dev/null || true)"
  if [ -z "$brew_bin" ]; then
    return 1
  fi

  eval "$("$brew_bin" shellenv)"
}

install_brew_packages() {
  local brew_bin
  local -a formula_missing=()
  local -a cask_missing=()

  install_homebrew
  brew_bin="$(brew_path)"
  eval "$("$brew_bin" shellenv)"

  {{- range .packages.darwin.brew }}
  if ! brew list --versions "{{ . }}" >/dev/null 2>&1; then
    formula_missing+=("{{ . }}")
  fi
  {{- end }}

  {{- range .packages.darwin.cask }}
  if ! brew list --cask --versions "{{ . }}" >/dev/null 2>&1; then
    cask_missing+=("{{ . }}")
  fi
  {{- end }}

  if [ "${#formula_missing[@]}" -gt 0 ]; then
    log "installing Homebrew packages: ${formula_missing[*]}"
    brew install "${formula_missing[@]}"
  fi

  if [ "${#cask_missing[@]}" -gt 0 ]; then
    log "installing Homebrew casks: ${cask_missing[*]}"
    brew install --cask "${cask_missing[@]}"
  fi
}

install_fnm() {
  install_homebrew
  eval_brew_shellenv

  if have fnm; then
    return
  fi

  log "installing fnm"
  brew install fnm
}

fnm_has_installed_lts() {
  fnm list 2>/dev/null | grep -Fq 'lts-latest'
}

install_node_lts() {
  if ! have fnm; then
    warn "fnm is required to install Node.js LTS"
    return 1
  fi

  eval "$(fnm env --shell bash)"

  if fnm_has_installed_lts; then
    local current
    local default_version

    if fnm use --silent-if-unchanged lts-latest >/dev/null 2>&1; then
      current="$(fnm current 2>/dev/null || true)"
      default_version="$(fnm default 2>/dev/null || true)"

      if [ -n "$current" ] && [ "$current" != "system" ]; then
        if [ "$default_version" != "$current" ]; then
          fnm default "$current" >/dev/null 2>&1
        fi

        return 0
      fi
    fi

    warn "installed Node.js LTS could not be activated; reinstalling via fnm"
  fi

  log "installing latest Node.js LTS via fnm"
  fnm install --lts --use
  fnm default "$(fnm current)" >/dev/null 2>&1
}

detect_linux_id() {
  if [ ! -r /etc/os-release ]; then
    warn "missing /etc/os-release"
    return 1
  fi

  . /etc/os-release
  printf '%s\n' "${ID:-}"
}

apt_package_available() {
  apt-cache show "$1" >/dev/null 2>&1
}

install_apt_packages() {
  local distro
  local -a packages=()
  local -a missing=()

  distro="$(detect_linux_id)"

  case "$distro" in
    debian)
      {{- range .packages.debian.apt }}
      packages+=("{{ . }}")
      {{- end }}
      ;;
    ubuntu)
      {{- range .packages.ubuntu.apt }}
      packages+=("{{ . }}")
      {{- end }}
      ;;
    *)
      warn "unsupported Linux distribution: $distro"
      return 1
      ;;
  esac

  log "refreshing apt metadata"
  run_sudo apt-get update

  for package in "${packages[@]}"; do
    if ! dpkg -s "$package" >/dev/null 2>&1; then
      missing+=("$package")
    fi
  done

  if [ "${#missing[@]}" -gt 0 ]; then
    log "installing apt packages: ${missing[*]}"
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "${missing[@]}"
  fi

  if ! have unzip; then
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y unzip
  fi

  if ! have starship; then
    if apt_package_available starship; then
      run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y starship
    else
      install_starship
    fi
  fi

  if ! have zoxide; then
    if apt_package_available zoxide; then
      run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y zoxide
    else
      install_zoxide
    fi
  fi
}

install_linux_desktop_packages() {
  local -a packages=(
    xfce4
    xfce4-goodies
    xorg
    dbus-x11
    x11-xserver-utils
    wget
    curl
    unzip
  )
  local -a missing=()
  local package

  for package in "${packages[@]}"; do
    if ! dpkg -s "$package" >/dev/null 2>&1; then
      missing+=("$package")
    fi
  done

  if [ "${#missing[@]}" -gt 0 ]; then
    log "installing XFCE desktop packages: ${missing[*]}"
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "${missing[@]}"
  fi
}

install_vnc_desktop_packages() {
  local -a packages=(
    xvfb
    x11vnc
    openbox
    x11-xserver-utils
  )
  local -a missing=()
  local package

  for package in "${packages[@]}"; do
    if ! dpkg -s "$package" >/dev/null 2>&1; then
      missing+=("$package")
    fi
  done

  if [ "${#missing[@]}" -gt 0 ]; then
    log "installing headless VNC desktop packages: ${missing[*]}"
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "${missing[@]}"
  fi
}

ensure_xfce_session() {
  local session_file="$HOME/.xsession"

  if [ -f "$session_file" ]; then
    if grep -Fxq "startxfce4" "$session_file"; then
      return
    fi

    warn "$session_file already exists; leaving it unchanged"
    return
  fi

  printf 'startxfce4\n' > "$session_file"
}

install_xrdp() {
  if ! dpkg -s xrdp >/dev/null 2>&1; then
    log "installing xrdp"
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y xrdp
  fi
}

disable_xrdp() {
  if ! have systemctl; then
    return
  fi

  run_sudo systemctl disable --now xrdp xrdp-sesman >/dev/null 2>&1 || true
  run_sudo systemctl reset-failed xrdp xrdp-sesman >/dev/null 2>&1 || true
}

reconcile_xrdp_service() {
  if ! have systemctl; then
    {{- if $installDesktopRdp }}
    warn "systemctl is not available; enable and start xrdp manually"
    {{- end }}
    return
  fi

  {{- if $installDesktopRdp }}
  run_sudo systemctl enable xrdp >/dev/null 2>&1 || warn "could not enable xrdp automatically"
  run_sudo systemctl start xrdp >/dev/null 2>&1 || warn "could not start xrdp automatically"
  {{- else }}
  disable_xrdp
  {{- end }}
}

maybe_prompt_for_vnc_password() {
  local password_dir="$HOME/.vnc"
  local password_file="$password_dir/passwd"

  if [ -f "$password_file" ]; then
    return
  fi

  mkdir -p "$password_dir"

  if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
    warn "set a VNC password later with: x11vnc -storepasswd \"$password_file\""
    return
  fi

  log "set a VNC password for x11vnc"
  if ! x11vnc -storepasswd "$password_file" </dev/tty >/dev/tty 2>/dev/tty; then
    warn "x11vnc password setup was skipped; run: x11vnc -storepasswd \"$password_file\""
    return
  fi

  chmod 0600 "$password_file" 2>/dev/null || true
}

write_vnc_start_script() {
  local tmp_file

  tmp_file="$(mktemp)"
  cat >"$tmp_file" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

export DISPLAY="${DISPLAY:-:99}"
screen_spec="${DOTFILES_VNC_SCREEN:-1440x900x24}"
password_file="$HOME/.vnc/passwd"

if [ ! -f "$password_file" ]; then
  printf '[dotfiles vnc] missing VNC password file: %s\n' "$password_file" >&2
  exit 1
fi

Xvfb "$DISPLAY" -screen 0 "$screen_spec" +extension RANDR &
sleep 1
if command -v xsetroot >/dev/null 2>&1; then
  xsetroot -display "$DISPLAY" -solid '#2f3442' || true
fi
openbox &
sleep 1

exec x11vnc \
  -display "$DISPLAY" \
  -forever \
  -shared \
  -rfbauth "$password_file" \
  -rfbport 5900 \
  -noxdamage
EOF

  install -m 0755 "$tmp_file" "{{ $vncStartScript }}"
  rm -f "$tmp_file"
}

write_vnc_service() {
  local tmp_file

  tmp_file="$(mktemp)"
  cat >"$tmp_file" <<EOF
[Unit]
Description=Dotfiles Virtual Display (Xvfb + Openbox + x11vnc)
After=network.target

[Service]
Type=simple
User=$USER
Environment=HOME=$HOME
Environment=DISPLAY=:99
Environment=DOTFILES_VNC_SCREEN=1440x900x24
WorkingDirectory=$HOME
ExecStart={{ $vncStartScript }}
Restart=always
RestartSec=2
KillMode=control-group

[Install]
WantedBy=multi-user.target
EOF

  run_sudo install -m 0644 "$tmp_file" "{{ $vncServicePath }}"
  rm -f "$tmp_file"
}

disable_vnc_service() {
  rm -f "{{ $vncStartScript }}"

  if ! have systemctl; then
    return
  fi

  run_sudo systemctl disable --now "{{ $vncServiceName }}" >/dev/null 2>&1 || true
  run_sudo systemctl reset-failed "{{ $vncServiceName }}" >/dev/null 2>&1 || true
  run_sudo rm -f "{{ $vncServicePath }}" >/dev/null 2>&1 || true
  run_sudo systemctl daemon-reload >/dev/null 2>&1 || warn "could not reload systemd after removing the VNC display service"
}

reconcile_vnc_service() {
  {{- if $installDesktopVnc }}
  if [ ! -f "$HOME/.vnc/passwd" ]; then
    warn "desktop-vnc is selected but $HOME/.vnc/passwd is missing; the VNC display service will stay disabled until a password is set"
    disable_vnc_service
    return
  fi

  write_vnc_start_script

  if ! have systemctl; then
    warn "systemctl is not available; start {{ $vncStartScript }} manually after login"
    return
  fi

  write_vnc_service
  run_sudo systemctl daemon-reload >/dev/null 2>&1 || warn "could not reload systemd for the VNC display service"
  run_sudo systemctl enable "{{ $vncServiceName }}" >/dev/null 2>&1 || warn "could not enable the VNC display service automatically"
  run_sudo systemctl restart "{{ $vncServiceName }}" >/dev/null 2>&1 || warn "could not start the VNC display service automatically"
  {{- else }}
  disable_vnc_service
  {{- end }}
}

install_google_chrome() {
  local architecture
  local archive_dir
  local archive_path

  if dpkg -s google-chrome-stable >/dev/null 2>&1; then
    return
  fi

  architecture="$(dpkg --print-architecture 2>/dev/null || true)"
  case "$architecture" in
    amd64|"")
      ;;
    *)
      warn "skipping Google Chrome install on unsupported architecture: $architecture"
      return
      ;;
  esac

  archive_dir="$(mktemp -d)"
  archive_path="$archive_dir/google-chrome-stable_current_amd64.deb"

  # Let apt's _apt sandbox read the local archive instead of falling back to root.
  chmod 0755 "$archive_dir"

  log "installing Google Chrome"
  download_to "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb" "$archive_path"
  chmod 0644 "$archive_path"
  run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "$archive_path"
  rm -rf "$archive_dir"
}

install_openclaw() {
  if have openclaw; then
    return
  fi

  log "installing OpenClaw"
  download "https://openclaw.ai/install.sh" | bash -s -- --no-onboard
}

ensure_openclaw_runtime_config() {
  {{- if not $installOpenClaw }}
  return
  {{- else }}
  if mkdir -p "{{ $openClawCompileCache }}"; then
    chmod 0700 "{{ $openClawCompileCache }}" 2>/dev/null || true
  else
    warn "could not create OpenClaw compile cache directory at {{ $openClawCompileCache }}"
  fi
  {{- end }}
}

install_optional_linux_bootstrap_extras() {
  {{- if $installDesktopVnc }}
  install_vnc_desktop_packages
  maybe_prompt_for_vnc_password
  {{- end }}

  {{- if $installDesktopRdp }}
  install_linux_desktop_packages
  ensure_xfce_session
  install_xrdp
  {{- end }}

  {{- if $installChrome }}
  install_google_chrome
  {{- end }}

  {{- if $installOpenClaw }}
  install_openclaw
  ensure_openclaw_runtime_config
  {{- end }}

  reconcile_xrdp_service
  reconcile_vnc_service
}

install_starship() {
  if [ -x "$HOME/.local/bin/starship" ] || have starship; then
    return
  fi

  local target
  local tmpdir
  local archive

  target="$(starship_release_target 2>/dev/null || true)"
  if [ -z "$target" ]; then
    warn "unsupported platform for starship fallback: $(uname -s)/$(uname -m)"
    return 0
  fi

  tmpdir="$(mktemp -d)"
  archive="$tmpdir/starship.tar.gz"

  log "installing starship"
  # Use the release asset directly instead of the upstream installer script.
  download_to "https://github.com/starship/starship/releases/latest/download/starship-${target}.tar.gz" "$archive"
  tar -xzf "$archive" -C "$tmpdir"
  install -m 0755 "$tmpdir/starship" "$HOME/.local/bin/starship"
  rm -rf "$tmpdir"
}

starship_release_target() {
  case "$(uname -s):$(uname -m)" in
    Darwin:arm64|Darwin:aarch64)
      printf '%s\n' "aarch64-apple-darwin"
      ;;
    Darwin:x86_64)
      printf '%s\n' "x86_64-apple-darwin"
      ;;
    Linux:x86_64)
      printf '%s\n' "x86_64-unknown-linux-musl"
      ;;
    Linux:arm64|Linux:aarch64)
      printf '%s\n' "aarch64-unknown-linux-musl"
      ;;
    Linux:armv6l|Linux:armv7l)
      printf '%s\n' "arm-unknown-linux-musleabihf"
      ;;
    *)
      return 1
      ;;
  esac
}

install_zoxide() {
  if [ -x "$HOME/.local/bin/zoxide" ] || have zoxide; then
    return
  fi

  log "installing zoxide"
  download "https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh" | sh -s -- --bin-dir "$HOME/.local/bin" --man-dir "$HOME/.local/share/man"
}

install_uv() {
  if [ -x "$HOME/.local/bin/uv" ] || have uv; then
    return
  fi

  log "installing uv"
  UV_NO_MODIFY_PATH=1 download "https://astral.sh/uv/install.sh" | sh
}

install_bun() {
  if [ -x "$HOME/.bun/bin/bun" ] || have bun; then
    return
  fi

  if ! have unzip; then
    warn "bun requires unzip"
    return 1
  fi

  log "installing bun"
  BUN_INSTALL="$HOME/.bun" download "https://bun.sh/install" | bash
}

install_uv_tools() {
  {{- if gt (len .packages.uv.tools) 0 }}
  if ! have uv && [ ! -x "$HOME/.local/bin/uv" ]; then
    return
  fi

  {{- range .packages.uv.tools }}
  uv tool install "{{ . }}"
  {{- end }}
  {{- else }}
  :
  {{- end }}
}

install_bun_packages() {
  {{- if gt (len .packages.bun.packages) 0 }}
  if ! have bun && [ ! -x "$HOME/.bun/bin/bun" ]; then
    return
  fi

  {{- range .packages.bun.packages }}
  bun install --global "{{ . }}"
  {{- end }}
  {{- else }}
  :
  {{- end }}
}

ensure_fd_symlink() {
  if have fd || ! have fdfind; then
    return
  fi

  mkdir -p "$HOME/.local/bin"
  ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
}

main() {
  if [ "${DOTFILES_SKIP_PACKAGES:-0}" = "1" ]; then
    log "skipping package installation"
    exit 0
  fi

  ensure_local_bin

  case "{{ .chezmoi.os }}" in
    darwin)
      install_brew_packages
      ;;
    linux)
      install_apt_packages
      install_optional_linux_bootstrap_extras
      ;;
    *)
      warn "unsupported operating system: {{ .chezmoi.os }}"
      exit 1
      ;;
  esac

  install_uv
  install_bun
  install_fnm
  install_node_lts
  ensure_fd_symlink
  install_uv_tools
  install_bun_packages
}

main "$@"
