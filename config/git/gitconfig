[user]
    name = Markeljan Sokoli
    email = Markeljan19@gmail.com

[init]
    defaultBranch = main

[core]
    editor = nvim
    autocrlf = input

[pull]
    rebase = false

[fetch]
    prune = true

[alias]
    st = status -sb
    co = checkout
    br = branch
    cm = commit -m
    lg = log --graph --oneline --decorate --all

[include]
    path = ~/.gitconfig.local

